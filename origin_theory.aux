\@writefile{toc}{\contentsline {section}{\numberline {2}The ``$8$'' is triply forced: geometry $=$ lattice $=$ gravity}{2}{section.2}\protected@file@percent }
\newlabel{sec:eight}{{2}{2}{The ``$8$'' is triply forced: geometry $=$ lattice $=$ gravity}{section.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces The seam denominator $8$ is fixed three independent ways. If the seam is a horizon, the gravitational $8\pi $ (Hawking temperature $T_H=c_3/M$, Einstein $G_{\mu \nu }=8\pi T_{\mu \nu }$) forces $c_3$; it must then coincide with the geometric $2|\mu _4|$ (Gauss--Bonnet seam winding) and the lattice $\operatorname  {rank}E_8$. All three give $8$. {\small  \textcolor {tfgreen}{\textbf  {[I]}}}\ (\,{\footnotesize  \textcolor {tfblue!70!black}{[\,\texttt  {verification/v54\_seam\_horizon\_keystones.py}\,]}})}}{3}{figure.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces One orientation, two sectors: the anchor configuration is the stationary repeller of the natural functional --- the cubic flavor potential (curvatures $\pm \Delta $) and the SdS entropy (curvature $2/9=|\mathbb  Z_2|/N_{\mathrm  {fam}}^2$). {\small  \textcolor {tfgreen}{\textbf  {[I]}}}\ (\,{\footnotesize  \textcolor {tfblue!70!black}{[\,\texttt  {verification/v102\_seam\_orientation.py}\,]}}); the common-principle reading stays {\small  \textcolor {tfgold}{\textbf  {[P]}}}.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:orientation-origin}{{2}{4}{One orientation, two sectors: the anchor configuration is the stationary repeller of the natural functional --- the cubic flavor potential (curvatures $\pm \Delta $) and the SdS entropy (curvature $2/9=|\Z _2|/\Nfam ^2$). \tI \ (\veri {v102\_seam\_orientation.py}); the common-principle reading stays \tP }{figure.2}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3}A cyclic element \emph  {inside} the hull: the order-$30$ Coxeter rotation}{4}{section.3}\protected@file@percent }
\newlabel{sec:coxeter}{{3}{4}{A cyclic element \emph {inside} the hull: the order-$30$ Coxeter rotation}{section.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces The $E_8$ Coxeter element (built from the Cartan matrix as $c=s_1\cdots  s_8$) has order exactly $h(E_8)=30$; its eigenvalues are the primitive $30$th roots $e^{2\pi i m/30}$ with $m$ the $E_8$ exponents $\{1,7,11,13,17,19,23,29\}$, which are precisely the $\varphi (30)=8$ totatives of $30$. The phases pair as $m+(30{-}m)=30$ into $|\mu _4|=4$ invariant $2$-planes. {\small  \textcolor {tfblue}{\textbf  {[L]}}}\ (\,{\footnotesize  \textcolor {tfblue!70!black}{[\,\texttt  {verification/v55\_coxeter\_cycle.py}\,]}})}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:coxeter}{{3}{4}{The $E_8$ Coxeter element (built from the Cartan matrix as $c=s_1\cdots s_8$) has order exactly $h(E_8)=30$; its eigenvalues are the primitive $30$th roots $e^{2\pi i m/30}$ with $m$ the $E_8$ exponents $\{1,7,11,13,17,19,23,29\}$, which are precisely the $\varphi (30)=8$ totatives of $30$. The phases pair as $m+(30{-}m)=30$ into $|\mu _4|=4$ invariant $2$-planes. \tL \ (\veri {v55\_coxeter\_cycle.py})}{figure.3}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4}The unique attractor: a gapped transport selects ONE fixed point}{5}{section.4}\protected@file@percent }
\newlabel{sec:attractor}{{4}{5}{The unique attractor: a gapped transport selects ONE fixed point}{section.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces The transport spectrum $\{1,(2/3)^6,(1/3)^6\}$ has spectral gap $\Delta =-\log (2/3)^6=2.4328>0$. By Perron--Frobenius the operator has a unique dominant eigenvector; iterating from \emph  {any} start converges to the same fixed direction at the geometric rate $\lambda _2/\lambda _1=(2/3)^6$ --- the same $\lambda _2$ that fixes flavor and horizon recovery. {\small  \textcolor {tfgreen}{\textbf  {[I]}}}/{\small  \textcolor {tfblue}{\textbf  {[L]}}}\ (\,{\footnotesize  \textcolor {tfblue!70!black}{[\,\texttt  {verification/v56\_unique\_attractor.py}\,]}})}}{5}{figure.4}\protected@file@percent }
\newlabel{fig:attractor}{{4}{5}{The transport spectrum $\{1,(2/3)^6,(1/3)^6\}$ has spectral gap $\Delta =-\log (2/3)^6=2.4328>0$. By Perron--Frobenius the operator has a unique dominant eigenvector; iterating from \emph {any} start converges to the same fixed direction at the geometric rate $\lambda _2/\lambda _1=(2/3)^6$ --- the same $\lambda _2$ that fixes flavor and horizon recovery. \tI /\tL \ (\veri {v56\_unique\_attractor.py})}{figure.4}{}}
