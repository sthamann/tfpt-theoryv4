\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \emph  {Left:} Histogram of the Lemma-E branch phases \(\varphi _j=\arg \langle e_j,u_\Sigma \rangle \) for the \(M=192\) candidate-v4.6 modes. Note the explicit absence of the uniform distribution: the seam projection imprints a non-trivial phase structure that, in a real branch, would lift the random-realisation degeneracy. \emph  {Right:} The spectrum \(\{\lambda _j\}\) of the candidate \(K_\Sigma \), log-scaled. Both quantities are reproducible from the seven primitives, with the rng seed fixing only the spectral-flag rotation.}}{13}{figure.caption.4}\protected@file@percent }
\newlabel{fig:phij}{{4}{13}{\emph {Left:} Histogram of the Lemma-E branch phases \(\varphi _j=\arg \langle e_j,u_\Sigma \rangle \) for the \(M=192\) candidate-v4.6 modes. Note the explicit absence of the uniform distribution: the seam projection imprints a non-trivial phase structure that, in a real branch, would lift the random-realisation degeneracy. \emph {Right:} The spectrum \(\{\lambda _j\}\) of the candidate \(K_\Sigma \), log-scaled. Both quantities are reproducible from the seven primitives, with the rng seed fixing only the spectral-flag rotation}{figure.caption.4}{}}
\newlabel{fig:phij@cref}{{[figure][4][]4}{[1][13][]13}{}{}{}}
