\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces TFPT v4.6.3 vs Planck PR3 SMICA. \emph  {Top-left:} Planck SMICA (PR3) downgraded to \(N_{\mathrm  {side}}=1024\). \emph  {Top-right:} TFPT Mode~A (random sample from \(C_\ell ^{\mathrm  {TFPT,v4.6}}\) with seed~42, lensed, birefringence~applied). \emph  {Bottom-left:} TFPT Mode~E (Lemma-E branch phases, candidate v4.6, \(N_{\mathrm  {side}}=512\)). \emph  {Bottom-right:} Planck \(-\) TFPT Mode~A residual (RMS \(\approx 153\,\mu \mathrm  {K}\)). Mode~A is statistically indistinguishable from Planck SMICA at the eyeball level; this is expected, because A--D give the correct \(C_\ell \) and Mode~A injects random phases. Mode~E uses fixed phases coming from the spectrum of \(K_\Sigma \); the residual against Planck is \(13\,\%\) smaller.}}{12}{figure.caption.2}\protected@file@percent }
\newlabel{fig:mollweide}{{2}{12}{TFPT v4.6.3 vs Planck PR3 SMICA. \emph {Top-left:} Planck SMICA (PR3) downgraded to \(N_{\mathrm {side}}=1024\). \emph {Top-right:} TFPT Mode~A (random sample from \(C_\ell ^{\mathrm {TFPT,v4.6}}\) with seed~42, lensed, birefringence~applied). \emph {Bottom-left:} TFPT Mode~E (Lemma-E branch phases, candidate v4.6, \(N_{\mathrm {side}}=512\)). \emph {Bottom-right:} Planck \(-\) TFPT Mode~A residual (RMS \(\approx 153\,\mu \mathrm {K}\)). Mode~A is statistically indistinguishable from Planck SMICA at the eyeball level; this is expected, because A--D give the correct \(C_\ell \) and Mode~A injects random phases. Mode~E uses fixed phases coming from the spectrum of \(K_\Sigma \); the residual against Planck is \(13\,\%\) smaller}{figure.caption.2}{}}
\newlabel{fig:mollweide@cref}{{[figure][2][]2}{[1][12][]12}{}{}{}}
